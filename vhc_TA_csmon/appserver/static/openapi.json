    "servers": [
        {
            "url": "https://{domain}:{port}/servicesNS/-/vhc_TA_csmon",
            "variables": {
                "domain": {
                    "default": "localhost"
                },
                "port": {
                    "default": "8089"
                }
            },
            "description": "Access via management interface"
        }
    ],
    "components": {

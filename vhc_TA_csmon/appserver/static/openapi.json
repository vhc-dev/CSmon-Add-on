                    "sap_systems": {
                        "type": "string"
                    },
                    "hana_systems": {
                        "type": "string"
                    }
                }
            },
            "system_settings_without_name": {
                "type": "object",
                "properties": {
                    "sap_systems": {
                        "type": "string"
                    },
                    "hana_systems": {
                        "type": "string"
                    }
                }
            },
            "modus_settings": {
                "type": "object",
                "properties": {
                    "test_mode": {
                        "type": "string"
                    }
                }
            },
            "modus_settings_without_name": {
                "type": "object",
                "properties": {
                    "test_mode": {
                        "type": "string"
                    }
                }
            },
            "logging": {
                "type": "object",
                "properties": {
                    "loglevel": {
                        "type": "string",
                        "enum": [
                            "DEBUG",
                            "INFO",
                            "WARNING",
                            "ERROR",
                            "CRITICAL"
                        ]
